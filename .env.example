PROJECT_NAME="AI Technical Interviewer Voice System"
API_VERSION=0.1.0
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/interviewer
BACKEND_CORS_ORIGINS=http://localhost:3000,http://frontend:3000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ASSEMBLYAI_API_KEY=
ASSEMBLYAI_SPEECH_MODEL=universal-3-pro
ASSEMBLYAI_LANGUAGE_CODE=es
ASSEMBLYAI_LANGUAGE_DETECTION=false
ASSEMBLYAI_SAMPLE_RATE=16000

CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-2
CARTESIA_VERSION=2026-03-01
CARTESIA_OUTPUT_CONTAINER=wav
CARTESIA_OUTPUT_ENCODING=pcm_f32le
CARTESIA_SAMPLE_RATE=44100

NEXT_PUBLIC_API_URL=http://localhost:8000
PUBLIC_BACKEND_URL=http://localhost:8000
PUBLIC_FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

AUDIO_STORAGE_DIR=storage/audio
SEED_DEMO_TEMPLATES=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=
